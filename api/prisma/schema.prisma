// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // Hashed via bcrypt
  name        String 
  role        String   @default("employee") // admin, employee, client
  status      String   @default("active")   // active, suspended
  resetToken  String?
  resetTokenExpiry DateTime?
  clientId    String?  // If role is client, associate with a Client profile
  avatar      String?  // Base64 image data or URL for profile picture
  preferences Json?    // UI layout preferences, module configs, dashboard state
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id        String    @id @default(uuid())
  name      String
  contact   String
  email     String
  phone     String
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id              String   @id @default(uuid())
  name            String
  clientId        String?
  clientName      String?  // Explicitly stores typed text for the frontend
  client          Client?  @relation(fields: [clientId], references: [id])
  reference       String?
  status          String   @default("Queue") // Queue, Active, Revising, Completed
  progress        Int      @default(0)
  assignee        String?
  dueDate         String?
  totalAmount     Float    @default(0)
  deposit         Float    @default(0)
  revisionCount   Int      @default(0)
  services        Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
}

model Lead {
  id            String   @id @default(uuid())
  company       String
  website       String?
  email         String?
  phone         String?
  status        String   @default("Discovered") // Discovered, Contacted, Proposal Sent, Won
  value         String?
  addedDate     String?
  intentScore   Int      @default(50)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Task {
  id        String   @id @default(uuid())
  title     String
  assignee  String?
  dueDate   String?
  priority  String   @default("Medium") // High, Medium, Low
  status    String   @default("Pending") // Pending, Completed
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  projectId String?
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id          String   @id @default(uuid())
  name        String
  type        String
  projectId   String?
  folderId    String?
  size        String?
  url         String?
  comments    Json?
  annotations Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Channel {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("channel") // channel, deal
  referenceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id          String   @id @default(uuid())
  channelId   String
  sender      String
  text        String?
  imageUrl    String?
  timestamp   DateTime @default(now())
  read        Boolean  @default(false)
  reactions   Json?
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("employee")
  status    String   @default("active")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

